{
	"require": {
		"php-http/curl-client": "^2.2",
		"typesense/typesense-php": "^4.8",
		"symfony/http-client": "^5.4"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.5",
		"squizlabs/php_codesniffer": "^3.7",
		"phpstan/phpstan": "^1.8",
		"wp-coding-standards/wpcs": "^3.1",
		"dealerdirect/phpcodesniffer-composer-installer": "^0.7"
	},
	"autoload": {
		"psr-4": {
			"BlazeWooless\\": "app/"
		}
	},
	"scripts": {
		"test": "phpunit",
		"test:unit": "phpunit --testsuite=\"BlazeCommerce Unit Tests\"",
		"test:integration": "phpunit --testsuite=\"BlazeCommerce Integration Tests\"",
		"test:cli": "phpunit --testsuite=\"BlazeCommerce CLI Tests\"",
		"test:coverage": "phpunit --coverage-html tests/coverage/html",
		"cs:check": "phpcs --standard=phpcs.xml",
		"cs:fix": "phpcbf --standard=phpcs.xml",
		"cs:fix-file": "phpcbf --standard=phpcs.xml",
		"cs:fix-all": "phpcbf --standard=phpcs.xml --ignore=vendor/,tests/coverage/,node_modules/,build/ .",
		"analyze": "phpstan analyse --level=5 app/",
		"lint": "composer cs:check && composer analyze",
		"fix": "composer cs:fix && echo 'Code formatting completed!'"
	},
	"config": {
		"allow-plugins": {
			"php-http/discovery": true,
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
